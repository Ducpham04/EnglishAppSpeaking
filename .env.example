# =============================================
# GB Speaking AI — Environment Variables
# Copy this file to .env.local and fill in values
# =============================================

# Required: PostgreSQL database and app URL
DATABASE_URL=postgresql://user:password@localhost:5432/gb_speaking_ai
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# --- AI Provider ---
# Groq is tried first. If all Groq models fail because of quota/rate limits,
# the app automatically falls back to Gemini, then OpenAI.
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional Google Gemini fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq (optional) - leave GROQ_MODELS empty to auto-load all active Groq models
GROQ_API_KEY=gsk-your-groq-api-key-here
GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
GROQ_MODELS=
# Optional manual order, comma-separated:
# GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,openai/gpt-oss-20b,openai/gpt-oss-120b

# Groq Speech-to-Text (Whisper)
GROQ_STT_ENDPOINT=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_STT_MODEL=whisper-large-v3-turbo
SPEECH_RATE_LIMIT_PER_IP_PER_HOUR=60

# Hugging Face (optional)
HF_API_KEY=
HF_MODEL=meta-llama/Llama-2-13b-chat

# App metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GB Speaking AI

# --- Manual QR payment ---
# Put your QR image in a public URL, or upload public/payment-qr.png and use /payment-qr.png
NEXT_PUBLIC_PAYMENT_QR_IMAGE_URL=
NEXT_PUBLIC_PAYMENT_BANK_NAME=
NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=
NEXT_PUBLIC_PAYMENT_ACCOUNT_NUMBER=
NEXT_PUBLIC_PAYMENT_NOTE_PREFIX=GBSPEAKING
NEXT_PUBLIC_PAYMENT_CONTACT=Admin sẽ kích hoạt gói sau khi xác nhận chuyển khoản.

# --- Observability (optional Sentry) ---
# Without these values, Sentry stays disabled and the app still runs normally.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1

# --- Rate limiting (optional, production only) ---
# Max AI requests per IP per hour
AI_RATE_LIMIT_PER_IP_PER_HOUR=20

# --- Commercial quota controls ---
# Per authenticated user. The API blocks before calling the AI provider.
AI_DAILY_USER_TOKEN_LIMIT=60000
AI_MONTHLY_USER_TOKEN_LIMIT=1200000
AI_DAILY_WARNING_PERCENT=80
