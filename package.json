{
  "name": "gb-speaking-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "prisma migrate deploy && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "predeploy:check": "npm run lint && npm run type-check && npm test -- --run && npm run build",
    "smoke:load": "node scripts/load-smoke.js",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev --name init",
    "prisma:seed": "prisma db seed",
    "prisma:seed:demo": "tsx prisma/seed-demo.ts",
    "format": "prettier --write .",
    "test": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.56.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.11",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.39.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "sharp": "^0.35.0",
    "postcss": "^8.5.10"
  }
}
